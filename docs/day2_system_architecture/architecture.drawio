        <mxCell id="2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#bfdbfe;fontColor=#111827;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" value="&lt;b&gt;Raw EHR Data Sources&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;• MIMIC-III / MIMIC-IV / eICU tables&lt;br/&gt;• Diagnoses, procedures, meds, encounters&lt;br/&gt;• Demographics (age, sex)" vertex="1">
          <mxGeometry height="150" width="300" x="40" y="110" as="geometry" />
        </mxCell>
        <mxCell id="3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontColor=#111827;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" value="&lt;b&gt;Preprocessing &amp; Mapping&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;• Extract per-encounter event sequences&lt;br/&gt;• Normalize: ICD → SNOMED, Drug/NDC → RxNorm&lt;br/&gt;• Build splits + vocab + audit logs" vertex="1">
          <mxGeometry height="150" width="260" x="60" y="390" as="geometry" />
        </mxCell>
        <mxCell id="4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontColor=#111827;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" value="&lt;b&gt;Normalized Record Store&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;• Record = {events, demographics, raw_codes}&lt;br/&gt;• Canonical tokens used by all modules&lt;br/&gt;• Keeps traceability for debugging" vertex="1">
          <mxGeometry height="150" width="260" x="60" y="810" as="geometry" />
