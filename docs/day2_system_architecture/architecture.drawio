        <mxCell id="5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontColor=#111827;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" value="&lt;b&gt;Baseline Anomaly Detector&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;• Sequence model (GRU / Transformer)&lt;br/&gt;• Outputs detection score: S_det(X)&lt;br/&gt;• Optional: token-level surprise" vertex="1">
          <mxGeometry height="150" width="260" x="400" y="220" as="geometry" />
        </mxCell>
        <mxCell id="6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontColor=#111827;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" value="&lt;b&gt;Diffusion Generative Model&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;• Ontology-regularized generative prior&lt;br/&gt;• Outputs generative score: S_gen(X)&lt;br/&gt;• Optional: denoised / recon candidates" vertex="1">
          <mxGeometry height="150" width="260" x="420" y="585" as="geometry" />
        </mxCell>
        <mxCell id="7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontColor=#111827;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" value="&lt;b&gt;Ontology Engine&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;• Mappings + concept graph (SNOMED/RxNorm)&lt;br/&gt;• Rule checks → violations[]&lt;br/&gt;• Ontology score: S_ont(X) + labels/relations" vertex="1">
          <mxGeometry height="150" width="260" x="697" y="800" as="geometry" />
        </mxCell>
        <mxCell id="8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#bfdbfe;fontColor=#111827;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" value="&lt;b&gt;Score Orchestrator / Calibrator&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;• Aggregates: S_det, S_gen, S_ont&lt;br/&gt;• S_cal(X) = w1·S_gen + w2·S_ont&lt;br/&gt;• Builds ScorePack + metadata" vertex="1">
          <mxGeometry height="150" width="260" x="880" y="330" as="geometry" />
